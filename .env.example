# ── PayPortal BZ — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your real values.
# In Coolify: add these in the "Environment Variables" section of your service.
# NEVER commit .env with real keys to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stripe ───────────────────────────────────────────────────────────────────
# Paste your keys from https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# ── PlaceToPay / Atlantic Bank Belize ────────────────────────────────────────
# Get these credentials directly from Atlantic Bank Belize
PTP_LOGIN=your_merchant_login_here
PTP_SECRET=your_secret_key_here

# Confirm exact endpoint URL with Atlantic Bank
PTP_ENDPOINT=https://abgateway.atlabank.com/api/session

# URL to redirect customers to after payment completes
PTP_RETURN_URL=https://yourdomain.com/payment/return
