FROM node:18-alpine

WORKDIR /app

# Install dependencies first (layer cache)
COPY package.json .
RUN npm install --omit=dev

# Copy source
COPY server.js .

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD wget -qO- http://localhost:3000/api/health || exit 1

CMD ["node", "server.js"]
